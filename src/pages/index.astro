---
import "../styles/global.css";

import { Image } from "astro:assets";
import myImage from "/assets/ChairRender.png";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>iam(not)adrian</title>
  </head>

  <body>
    <div id="modal" class="modal hidden">
      <span id="close">×</span>
      <img id="modal-img" />
    </div>
    <header>
      <div>
        <h1>iam(not)adrian</h1>
        <p class="updated">Updated May 2026</p>
      </div>
      <a href="./blog">Blog</a>
      <!-- <a href="">github</a>-->
    </header>

    <main>
      <section class="intro">
        <p>I design and build apps that solve practical, everyday problems.</p>

        <p>
          I’m especially interested in day-to-day finance, personal money
          management, and simple tools that make complex decisions feel clearer.
          Outside of software, I like to touch grass and occasionally explore
          archviz.
        </p>

        <p>
          I write a blog where I occasionally share my thoughts on AI, finance,
          and everyday life.
        </p>

        <p>
          I study business informatics and work as a working student in process
          optimization at <a href="https://www.nafa.de">NAFA</a>.
        </p>
      </section>

      <section class="stuff" aria-labelledby="stuff-title">
        <h2 id="stuff-title" class="stuff-title">Projects</h2>

        <div class="stuff-list">
          <article class="stuff-row">
            <time class="stuff-year" datetime="2026">2026</time>
            <div class="stuff-entry">
              <a class="stuff-link" href="https://lily-eight-psi.vercel.app/">
                Lily <span class="new-badge">building</span>
              </a>
              <span class="stuff-category">Bicycle passport app</span>
            </div>
            <!--<time class="stuff-date" datetime="2025-05-23">2025</time>-->
          </article>

          <article class="stuff-row">
            <span class="stuff-year" aria-hidden="true"></span>
            <div class="stuff-entry deactivated">
              <a class="stuff-link" href="#"
                >Greenbacks <span class="new-badge">building</span>
              </a>
              <span class="stuff-category">Student finance app</span>
            </div>
            <!--<time class="stuff-date" datetime="2025-05-23">2025</time>-->
          </article>

          <article class="stuff-row">
            <time class="stuff-year" datetime="2025">2025</time>
            <div class="stuff-entry deactivated">
              <a class="stuff-link" href="#">nobs</a>
              <span class="stuff-category">Calorie tracking app concept</span>
            </div>
            <!--<time class="stuff-date" datetime="2025-05-23">2025</time>-->
          </article>

          <article class="stuff-row">
            <span class="stuff-year" aria-hidden="true"></span>
            <div class="stuff-entry deactivated">
              <a class="stuff-link" href="#">Don't Frogget To Drink</a>
              <span class="stuff-category">Hydration app concept</span>
            </div>
            <!--<time class="stuff-date" datetime="2025-05-23">2025</time>-->
          </article>
        </div>
      </section>
    </main>
  </body>

  <script src="../script/scripts.js"></script>
</html>
