---
import "../styles/global.css";

import { Image } from "astro:assets";
import myImage from "/assets/ChairRender.png";
---

<style>
  body {
    width: var(--content-width);
  }
  .projects {
    margin-top: 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .project-image {
    width: 100%;
    height: auto;
    border-radius: 4px;
    object-fit: cover;
  }

  .project-image {
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .project-click {
    cursor: pointer;
  }

  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.25s ease;
  }

  .modal img {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    border-radius: 0;
    transform: scale(1);
    transition: transform 0.25s ease;
  }

  .hidden {
    opacity: 0;
    pointer-events: none;
  }

  .hidden img {
    transform: scale(0.96);
  }

  #close {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 999;
    font-size: 2rem;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    line-height: 1;
    background: rgba(200, 200, 200, 0.2);
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  #close:hover {
    transform: translateX(-50%) scale(1.15);
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>iam(not)adrian</title>
  </head>

  <body>
    <div id="modal" class="modal hidden">
      <span id="close">×</span>
      <img id="modal-img" />
    </div>
    <header>
      <h1>iam(not)adrian</h1>
    </header>

    <main>
      <section class="intro">
        <p>
          i build apps, care about day-to-day finance, touch grass and
          occasionally dive into
          <abbr title="Computer Aided Design">CAD</abbr>
          and
          <abbr title="Architectural Visualization">ArchViz</abbr>.
        </p>

        <p>
          I am currently building <span class="deactivated">Greenbacks</span>, a
          simple money management app for students.
        </p>

        <p>
          I study business informatics and work as a working student in process
          optimization at <a href="https://www.nafa.de">NAFA</a>.
        </p>
      </section>

      <section class="projects">
        <h2>ArchViz & CAD</h2>
        <div class="grid">
          <div class="project">
            <div class="project-click" data-src={myImage.src}>
              <Image src={myImage} alt="Rendered Chair" class="project-image" />
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>

  <script src="../script/scripts.js"></script>
</html>
