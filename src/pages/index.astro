---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="iam(not)adrian"
  description="Adrian designs and builds simple apps, digital products and everyday tools."
  currentPath="/"
>
  <section class="intro">
    <p>
      I <span class="mark">design</span> and <span class="mark">build apps</span
      > that solve everyday problems.
    </p>

    <p>
      I’m especially interested in personal money management, and simple tools
      that make life easier. Outside of software, I like to touch grass and
      explore
      <!-- <abbr>CAD</abbr> (Computer Aided Design) and -->
      <a href="https://www.blender.org/" class="mark"> Blender</a>.
    </p>

    <!--  <p>
          I write a blog where I occasionally share my thoughts on AI, finance,
          and everyday life.
        </p> -->

    <p>
      I study business informatics and work as a working student in process
      optimization <span class="mark">@</span>
      <a href="https://www.nafa.de" class="mark">NAFA</a>.
    </p>
  </section>

  <section class="stuff" aria-labelledby="stuff-title">
    <h2 id="stuff-title" class="stuff-title">Projects</h2>

    <div class="stuff-list">
      <article class="stuff-row stuff-row--action">
        <!-- <time class="stuff-year" datetime="2026">2026</time> -->
        <div class="stuff-entry">
          <a class="stuff-link" href="https://lily-eight-psi.vercel.app/">
            Lily <span class="new-badge">under construction</span>
          </a>
          <!-- <p class="stuff-description">Bicycle passport app</p> -->
        </div>
        <a
          class="stuff-arrow"
          href="https://lily-eight-psi.vercel.app/"
          aria-label="Open Lily">&rarr;</a
        >
      </article>

      <article class="stuff-row stuff-row--action">
        <!-- <span class="stuff-year" aria-hidden="true"></span> -->
        <div class="stuff-entry">
          <a
            class="stuff-link"
            href="https://www.figma.com/design/XrsuPKc7Xauq80LtMqxLof/Moodbit?node-id=382-2514&t=VFMbTYa6YNoqwFzD-1"
            >Moodbit</a
          >
          <!-- <p class="stuff-description">Mental well being (concept)</p> -->
        </div>
        <a
          class="stuff-arrow"
          href="https://www.figma.com/design/XrsuPKc7Xauq80LtMqxLof/Herbstprojekt?node-id=0-1&t=Vwl93n53Ur2BlpwZ-1"
          aria-label="Open Moodbit">&rarr;</a
        >
      </article>

      <article class="stuff-row stuff-row--action deactivated">
        <!-- <time class="stuff-year" datetime="2026">2026</time> -->
        <div class="stuff-entry">
          <a class="stuff-link" href="#">Greenbacks </a>
          <!-- <p class="stuff-description">Personal finance app for students</p> -->
        </div>
        <a class="stuff-arrow" href="#" aria-label="Open Greenbacks">&rarr;</a>
      </article>

      <article class="stuff-row stuff-row--action deactivated">
        <!-- <time class="stuff-year" datetime="2025">2025</time> -->
        <div class="stuff-entry">
          <a
            class="stuff-link"
            href="https://www.figma.com/design/r9PFXKM2PUFkqZlGSctW5O/nobs.?node-id=0-1&t=HhSQc5tb2wIG8Y0y-1"
            >nobs</a
          >
          <!-- <p class="stuff-description">
                Minimal calorie tracking app (concept)
              </p> -->
        </div>
        <a
          class="stuff-arrow"
          href="https://www.figma.com/design/r9PFXKM2PUFkqZlGSctW5O/nobs.?node-id=0-1&t=HhSQc5tb2wIG8Y0y-1"
          aria-label="Open nobs">&rarr;</a
        >
      </article>

      <article class="stuff-row stuff-row--action deactivated">
        <!-- <span class="stuff-year" aria-hidden="true">2025</span> -->
        <div class="stuff-entry">
          <a
            class="stuff-link"
            href="https://www.figma.com/design/pPpI3iTtfeMbrtXiuhA0xz/Don-t-Frogget-To-Drink?node-id=0-1&t=K1vy5hv180YPnqDi-1"
            >Frogget To Drink</a
          >
          <!-- <p class="stuff-description">
                Playful hydration tracker (concept)
              </p> -->
        </div>
        <a
          class="stuff-arrow"
          href="https://www.figma.com/design/pPpI3iTtfeMbrtXiuhA0xz/Don-t-Frogget-To-Drink?node-id=0-1&t=K1vy5hv180YPnqDi-1"
          aria-label="Open Frogget To Drink">&rarr;</a
        >
      </article>
    </div>
  </section>
</BaseLayout>
