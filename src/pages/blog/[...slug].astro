---
import { existsSync, statSync } from "node:fs";
import path from "node:path";
import { getCollection, render } from "astro:content";
import {
  isPublicOrExternalUrl,
  resolveBlogAsset,
} from "../../lib/blogAssets";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog");
const postImage = post.data.image
  ? resolveBlogAsset(post.id, post.data.image)
  : undefined;
const downloadSource = post.data.downloadFile;
const postDownload = downloadSource
  ? resolveBlogAsset(post.id, downloadSource)
  : undefined;
const hasLocalDownload = Boolean(
  downloadSource && !isPublicOrExternalUrl(downloadSource),
);
const downloadFileName = downloadSource && hasLocalDownload
  ? downloadSource.replace(/^\.?\//, "")
  : undefined;
const downloadPath = downloadFileName
  ? path.join(process.cwd(), "src/content/blog", post.id, downloadFileName)
  : undefined;
const downloadName = (downloadFileName ?? downloadSource)
  ?.split("/")
  .pop()
  ?.split("?")[0];
const downloadExtension = downloadName
  ? path.extname(downloadName).replace(".", "").toUpperCase()
  : undefined;
const downloadSize = downloadPath && existsSync(downloadPath)
  ? `${Math.max(1, Math.ceil(statSync(downloadPath).size / 1024))} Kb`
  : undefined;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("de-DE", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(date);

const sharedTagCount = (tags: string[]) =>
  tags.filter((tag) => post.data.tags.includes(tag)).length;

const relatedPosts = allPosts
  .filter(
    (entry) => entry.id !== post.id && sharedTagCount(entry.data.tags) > 0,
  )
  .sort((a, b) => {
    const tagDifference =
      sharedTagCount(b.data.tags) - sharedTagCount(a.data.tags);

    if (tagDifference !== 0) {
      return tagDifference;
    }

    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);
const shareUrl = new URL(
  `/blog/${post.id}/`,
  Astro.site ?? Astro.url,
).toString();
const shareHref = `mailto:?subject=${encodeURIComponent(
  post.data.title,
)}&body=${encodeURIComponent(shareUrl)}`;
const encodedShareTitle = encodeURIComponent(post.data.title);
const encodedShareUrl = encodeURIComponent(shareUrl);
const shareOptions = [
  {
    label: "E-Mail",
    href: shareHref,
  },
  {
    label: "WhatsApp",
    href: `https://wa.me/?text=${encodedShareTitle}%20${encodedShareUrl}`,
  },
  {
    label: "LinkedIn",
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedShareUrl}`,
  },
  {
    label: "X",
    href: `https://twitter.com/intent/tweet?text=${encodedShareTitle}&url=${encodedShareUrl}`,
  },
];
---

<BaseLayout
  title={`${post.data.title} | iam(not)adrian`}
  description={post.data.description}
  image={postImage}
  type="article"
  currentPath={`/blog/${post.id}/`}
  lang="de"
>
  <article class="blog-post">
    <nav class="blog-post__back-nav" aria-label="Blog navigation">
      <a
        class="blog-post__back-arrow"
        href="/blog/"
        aria-label="Zurück zu allen Blogbeiträgen"
      >
        <span aria-hidden="true">&larr;</span>
        <span class="blog-post__back-label">Back</span>
      </a>
    </nav>

    <header class="blog-post__header">
      <h1>{post.data.title}</h1>

      <p class="blog-post__meta">
        <time datetime={post.data.pubDate.toISOString()}
          >{formatDate(post.data.pubDate)}</time
        >
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    {
      post.data.downloadFile && (
        <section class="download-section" aria-labelledby="download-title">
          <h2 id="download-title" class="stuff-title">
            Download
          </h2>

          <a class="download-file" href={postDownload} download>
            <span class="download-file__title">{post.data.title}</span>
            <span class="download-file__meta">
              {downloadExtension}
              {downloadSize && <span>{downloadSize}</span>}
            </span>
            <span class="download-file__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 4v11" />
                <path d="m7 10 5 5 5-5" />
                <path d="M5 20h14" />
              </svg>
            </span>
          </a>
        </section>
      )
    }

    <section class="share-section" aria-label="Beitrag teilen">
      <button
        class="share-link"
        type="button"
        aria-controls="share-modal"
        aria-expanded="false"
        aria-haspopup="dialog"
        data-share-open
      >
        <span>Share</span>
        <span class="share-link__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7" />
            <path d="M12 3v13" />
            <path d="m7 8 5-5 5 5" />
          </svg>
        </span>
      </button>
    </section>

    <div
      class="share-modal"
      id="share-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="share-modal-title"
      data-share-modal
      hidden
    >
      <div class="share-modal__panel">
        <div class="share-modal__header">
          <h2 id="share-modal-title">Share</h2>
          <button
            class="share-modal__close"
            type="button"
            aria-label="Share Dialog schließen"
            data-share-close
          >
            &times;
          </button>
        </div>

        <div class="share-modal__options">
          <button
            class="share-option"
            type="button"
            data-share-copy
            data-share-url={shareUrl}
          >
            Link kopieren
          </button>

          {
            shareOptions.map((option) => (
              <a
                class="share-option"
                href={option.href}
                target={option.href.startsWith("http") ? "_blank" : undefined}
                rel={
                  option.href.startsWith("http")
                    ? "noopener noreferrer"
                    : undefined
                }
              >
                {option.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </article>

  {
    relatedPosts.length > 0 && (
      <section class="related-posts" aria-labelledby="related-title">
        <h2 id="related-title" class="stuff-title">
          Related Posts
        </h2>

        <div class="stuff-list">
          {relatedPosts.map((relatedPost) => (
            <article class="stuff-row stuff-row--action">
              <div class="stuff-entry">
                <a class="stuff-link" href={`/blog/${relatedPost.id}/`}>
                  {relatedPost.data.title}
                </a>
              </div>
              <a
                class="stuff-arrow"
                href={`/blog/${relatedPost.id}/`}
                aria-label={`Open ${relatedPost.data.title}`}
              >
                &rarr;
              </a>
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
