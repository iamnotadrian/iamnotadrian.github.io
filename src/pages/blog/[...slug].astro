---
import { getCollection, render } from "astro:content";
import { resolveBlogAsset } from "../../lib/blogAssets";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog");
const postImage = resolveBlogAsset(post.id, post.data.image);
const postDownload = post.data.downloadFile
  ? resolveBlogAsset(post.id, post.data.downloadFile)
  : undefined;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("de-DE", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(date);

const sharedTagCount = (tags: string[]) =>
  tags.filter((tag) => post.data.tags.includes(tag)).length;

const relatedPosts = allPosts
  .filter((entry) => entry.id !== post.id && sharedTagCount(entry.data.tags) > 0)
  .sort((a, b) => {
    const tagDifference = sharedTagCount(b.data.tags) - sharedTagCount(a.data.tags);

    if (tagDifference !== 0) {
      return tagDifference;
    }

    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);
---

<BaseLayout
  title={`${post.data.title} | iam(not)adrian`}
  description={post.data.description}
  image={postImage}
  type="article"
  currentPath={`/blog/${post.id}/`}
  lang="de"
>
  <article class="blog-post">
    <nav class="blog-post__back-nav" aria-label="Blog navigation">
      <a class="blog-post__back-arrow" href="/blog/" aria-label="Zurück zu allen Blogbeiträgen"></a>
      <a class="blog-post__back-arrow" href="/blog/" aria-label="Zurück zu allen Blogbeiträgen"></a>
    </nav>

    <header class="blog-post__header">
      <p class="blog-post__meta">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span aria-hidden="true"> · </span>
        <span>{post.data.author}</span>
      </p>

      <h1>{post.data.title}</h1>
      <p class="blog-post__description">{post.data.description}</p>

      <ul class="tag-list" aria-label="Tags">
        {post.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>

    <img
      class="blog-post__image"
      src={postImage}
      alt=""
      width="960"
      height="540"
      loading="eager"
      decoding="async"
    />

    <div class="prose">
      <Content />
    </div>

    {
      post.data.downloadFile && (
        <section class="download-box" aria-labelledby="download-title">
          <div>
            <h2 id="download-title">Download</h2>
            <p>Zusätzliche Ressourcen herunterladen</p>
          </div>

          <a class="button-link" href={postDownload} download>
            PDF herunterladen
          </a>
        </section>
      )
    }
  </article>

  {
    relatedPosts.length > 0 && (
      <section class="related-posts" aria-labelledby="related-title">
        <h2 id="related-title" class="stuff-title">Related Posts</h2>

        <div class="blog-grid">
          {relatedPosts.map((relatedPost) => (
            <article class="blog-card blog-card--compact">
              <a class="blog-card__media" href={`/blog/${relatedPost.id}/`} aria-hidden="true" tabindex="-1">
                  <img
                  src={resolveBlogAsset(relatedPost.id, relatedPost.data.image)}
                  alt=""
                  width="640"
                  height="360"
                  loading="lazy"
                  decoding="async"
                />
              </a>

              <div class="blog-card__body">
                <h3 class="blog-card__title">
                  <a class="stuff-link" href={`/blog/${relatedPost.id}/`}>
                    {relatedPost.data.title}
                  </a>
                </h3>
                <p class="blog-card__description">{relatedPost.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
